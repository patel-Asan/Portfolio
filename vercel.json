{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/admin/messages/(.*)", "dest": "/api/admin/messages.js" },
    { "src": "/api/admin/messages", "dest": "/api/admin/messages.js" },
    { "src": "/api/admin/login", "dest": "/api/admin/login.js" },
    { "src": "/api/messages", "dest": "/api/messages.js" }
  ]
}
